# ════════════════════════════════════════════════════════
#  netlify.toml — Konfigurasi Netlify untuk Puskeswan
# ════════════════════════════════════════════════════════

[build]
  # Folder yang di-publish sebagai website publik
  publish = "public"
  # Folder tempat Netlify Functions berada
  functions = "netlify/functions"

# Redirect semua traffic ke index.html (Single Page App)
[[redirects]]
  from = "/*"
  to = "/index.html"
  status = 200

# Header keamanan untuk semua halaman
[[headers]]
  for = "/*"
  [headers.values]
    X-Frame-Options = "DENY"
    X-Content-Type-Options = "nosniff"
    Referrer-Policy = "strict-origin-when-cross-origin"
    Permissions-Policy = "geolocation=(), microphone=(), camera=()"

# Cache untuk aset statis
[[headers]]
  for = "*.html"
  [headers.values]
    Cache-Control = "public, max-age=0, must-revalidate"

# Function timeout (default 10 detik, max 26 detik untuk Spark plan)
[functions]
  node_bundler = "esbuild"

